# Sao chép file này thành `.env` rồi điền giá trị do bên cung cấp đưa.
#   cp .env.example .env

# URL của server (không có dấu "/" ở cuối)
API_URL=https://eoe-dashboard.smollan.com.vn

# JWT token để xác thực (Authorization: Bearer ...)
API_TOKEN=

# Loại tính toán: moft | hvn | sp
PROJECT="moft"

# Tháng cần tính, định dạng yyyy-MM. Để trống = tháng hiện tại.
# Khi chạy không có --ids, tool lấy tất cả audit của tháng này.
MONTH=